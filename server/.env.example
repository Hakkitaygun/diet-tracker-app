# Copy this file to .env and fill in your API keys
# DO NOT commit .env to git!

# OpenRouter API Key - https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional separate key for image analysis only (keeps chat quota isolated)
VISION_OPENROUTER_API_KEY=sk-or-your-vision-key-here

# Optional separate vision models list
OPENROUTER_VISION_MODELS=google/gemini-2.0-flash-exp:free,meta-llama/llama-3.2-11b-vision-instruct:free

# Groq API Key - https://console.groq.com
GROQ_API_KEY=gsk_your-key-here

# Google Gemini API Key - https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyYour_key_here

# Database
DATABASE_URL=sqlite:./database.db

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS if needed)
FRONTEND_URL=http://localhost:3000
